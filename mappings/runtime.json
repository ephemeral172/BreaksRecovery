{
  "batch_size_max_agents": 200,
  "batch_size_max_bytes": 262144,
  "wfms": {
    "retry_attempts": 3,
    "retry_backoff_sec": [1, 3, 9],
    "publish_after_each_chunk": true,
    "recalculate_fte_after_each_chunk": true
  },
  "wfm_db": {
    "retry_attempts": 3,
    "retry_backoff_sec": [1, 3, 9]
  },
  "mattermost": {
    "retry_attempts": 3,
    "retry_backoff_sec": [1, 3, 9],
    "channels": {
      "ops": "RPA_BN_BreaksRecovery",
      "errors": "RPA_Robot_Prod_Notifications"
    }
  },
  "smtp_fallback": {
    "host": "exchange.avito.ru",
    "port": 587,
    "tls": true,
    "retry_attempts": 2,
    "retry_interval_sec": 30
  },
  "scheduler": {
    "cron_ope": "0 13 * * *",
    "cron_prod": "30 19 * * *",
    "timezone": "Europe/Moscow",
    "target_day_offset": 1
  }
}
